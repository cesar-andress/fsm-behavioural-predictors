{
  "system_name": "Warehouse Inventory",
  "domain": "warehouse logistics",
  "states": [
    "Idle",
    "Stocked",
    "Allocated",
    "Dispatched"
  ],
  "initial_state": "Idle",
  "events": [
    "ReceiveStock",
    "Allocate",
    "Dispatch",
    "CancelAllocation",
    "Restock",
    "RejectAllocate",
    "RejectDispatch"
  ],
  "transitions": [
    {
      "source": "Idle",
      "event": "ReceiveStock",
      "target": "Stocked",
      "requirement": "R2"
    },
    {
      "source": "Stocked",
      "event": "Allocate",
      "target": "Allocated",
      "requirement": "R3"
    },
    {
      "source": "Allocated",
      "event": "Dispatch",
      "target": "Dispatched",
      "requirement": "R4"
    },
    {
      "source": "Allocated",
      "event": "CancelAllocation",
      "target": "Stocked",
      "requirement": "R5"
    },
    {
      "source": "Dispatched",
      "event": "Restock",
      "target": "Stocked",
      "requirement": "R6"
    },
    {
      "source": "Idle",
      "event": "Allocate",
      "target": "Idle",
      "guard": "rejected",
      "requirement": "R7"
    },
    {
      "source": "Stocked",
      "event": "Dispatch",
      "target": "Stocked",
      "guard": "rejected",
      "requirement": "R8"
    }
  ]
}
